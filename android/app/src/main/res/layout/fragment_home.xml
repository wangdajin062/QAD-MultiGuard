<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipe_refresh"
    android:layout_width="match_parent" android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:fillViewport="true" android:background="@color/bg_gray"
        android:overScrollMode="always">

        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingBottom="24dp">

            <!-- Hero Card: 问候 + 防护分数 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardBackgroundColor="@color/primary"
                app:cardCornerRadius="20dp" app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="24dp">

                    <!-- 顶部：问候 + 等级徽章 -->
                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_greeting"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Hi, 校园守护者"
                                android:textColor="#CCFFFFFF" android:textSize="14sp"
                                android:letterSpacing="0.02"/>

                            <TextView
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="防护状态"
                                android:textColor="@color/white" android:textSize="20sp"
                                android:textStyle="bold" android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <!-- 等级徽章 -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            app:cardCornerRadius="20dp"
                            app:cardBackgroundColor="#33FFFFFF"
                            app:cardElevation="0dp"
                            android:clickable="false">
                            <TextView
                                android:id="@+id/tv_protection_level"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="银盾"
                                android:textColor="@color/white" android:textSize="13sp"
                                android:textStyle="bold"
                                android:paddingHorizontal="20dp"
                                android:paddingVertical="8dp"/>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <!-- 分数 + 进度条 -->
                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginTop="20dp">

                        <TextView
                            android:id="@+id/tv_protection_score"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="60"
                            android:textColor="@color/white" android:textSize="52sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-condensed"/>

                        <LinearLayout
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <TextView
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="/ 100 分"
                                android:textColor="#CCFFFFFF" android:textSize="14sp"/>

                            <ProgressBar
                                android:id="@+id/progress_protection"
                                style="?android:attr/progressBarStyleHorizontal"
                                android:layout_width="match_parent" android:layout_height="8dp"
                                android:layout_marginTop="10dp"
                                android:max="100" android:progress="60"
                                android:progressTint="@color/white"
                                android:progressBackgroundTint="#44FFFFFF"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 状态描述 -->
                    <TextView
                        android:id="@+id/tv_score_desc"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/home_score_desc_good"
                        android:textColor="#CCFFFFFF" android:textSize="12sp"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 4 大统计卡片 -->
            <LinearLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingTop="4dp">

                <!-- 拦截来电 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginEnd="4dp"
                    app:cardCornerRadius="14dp" app:cardElevation="1dp"
                    app:cardBackgroundColor="@color/white"
                    android:clickable="false">
                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center"
                        android:padding="14dp">
                        <TextView android:id="@+id/tv_blocked_calls"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="24sp" android:textStyle="bold"
                            android:textColor="@color/risk_blue"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="拦截来电" android:textSize="11sp" android:textColor="@color/text_hint"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 短信预警 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginHorizontal="4dp"
                    app:cardCornerRadius="14dp" app:cardElevation="1dp"
                    app:cardBackgroundColor="@color/white"
                    android:clickable="false">
                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center"
                        android:padding="14dp">
                        <TextView android:id="@+id/tv_alerted_sms"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="24sp" android:textStyle="bold"
                            android:textColor="@color/risk_orange"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="短信预警" android:textSize="11sp" android:textColor="@color/text_hint"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 我的举报 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginHorizontal="4dp"
                    app:cardCornerRadius="14dp" app:cardElevation="1dp"
                    app:cardBackgroundColor="@color/white"
                    android:clickable="false">
                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center"
                        android:padding="14dp">
                        <TextView android:id="@+id/tv_total_reports"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="24sp" android:textStyle="bold"
                            android:textColor="@color/risk_red"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="我的举报" android:textSize="11sp" android:textColor="@color/text_hint"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 阅读案例 -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="4dp"
                    app:cardCornerRadius="14dp" app:cardElevation="1dp"
                    app:cardBackgroundColor="@color/white"
                    android:clickable="false">
                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center"
                        android:padding="14dp">
                        <TextView android:id="@+id/tv_cases_read"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="24sp" android:textStyle="bold"
                            android:textColor="@color/accent"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="阅读案例" android:textSize="11sp" android:textColor="@color/text_hint"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- 快捷入口 -->
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="20dp" android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"
                android:text="快速操作"
                android:textSize="16sp" android:textStyle="bold"
                android:textColor="@color/text_primary"/>

            <LinearLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp">

                <!-- 查号 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_quick_call"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:clickable="true" android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="16dp" app:cardElevation="1dp"
                    app:cardBackgroundColor="@color/white"
                    app:strokeWidth="1dp" app:strokeColor="@color/divider">
                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="32dp" android:layout_height="32dp"
                            android:src="@drawable/ic_call"
                            app:tint="@color/primary"
                            android:contentDescription="@string/home_quick_call"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="10dp" android:text="@string/home_quick_call"
                            android:textColor="@color/text_primary" android:textSize="14sp"
                            android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="号码风险" android:textColor="@color/text_hint" android:textSize="11sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 案例 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_quick_cases"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginHorizontal="8dp"
                    android:clickable="true" android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="16dp" app:cardElevation="1dp"
                    app:cardBackgroundColor="@color/white"
                    app:strokeWidth="1dp" app:strokeColor="@color/divider">
                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="32dp" android:layout_height="32dp"
                            android:src="@drawable/ic_case"
                            app:tint="@color/primary"
                            android:contentDescription="@string/home_quick_cases"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="10dp" android:text="@string/home_quick_cases"
                            android:textColor="@color/text_primary" android:textSize="14sp"
                            android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="典型案例" android:textColor="@color/text_hint" android:textSize="11sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- 举报 -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_quick_report"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:clickable="true" android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="16dp" app:cardElevation="1dp"
                    app:cardBackgroundColor="@color/white"
                    app:strokeWidth="1dp" app:strokeColor="@color/divider">
                    <LinearLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center"
                        android:padding="20dp">
                        <ImageView
                            android:layout_width="32dp" android:layout_height="32dp"
                            android:src="@drawable/ic_report"
                            app:tint="@color/primary"
                            android:contentDescription="@string/home_quick_report"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="10dp" android:text="@string/home_quick_report"
                            android:textColor="@color/text_primary" android:textSize="14sp"
                            android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="提交举报" android:textColor="@color/text_hint" android:textSize="11sp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- 今日提示 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_tip"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="16dp" app:cardElevation="1dp"
                app:cardBackgroundColor="@color/white"
                app:strokeWidth="1dp" app:strokeColor="@color/divider"
                android:clickable="false">
                <LinearLayout
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp"
                    android:background="@drawable/bg_tip_card">
                    <TextView
                        android:id="@+id/tv_tip_title"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/home_today_tip"
                        android:textColor="@color/accent" android:textSize="14sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tv_tip_content"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="10dp" android:text=""
                        android:textColor="@color/text_primary" android:textSize="14sp"
                        android:lineSpacingExtra="5dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 最新预警 Header -->
            <LinearLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingStart="20dp" android:paddingEnd="16dp"
                android:paddingTop="8dp" android:paddingBottom="12dp">
                <TextView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/home_latest_alerts"
                    android:textStyle="bold" android:textSize="16sp"
                    android:textColor="@color/text_primary"/>
                <TextView
                    android:id="@+id/tv_more_alerts"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/home_more"
                    android:textColor="@color/primary" android:textSize="13sp"
                    android:clickable="true" android:focusable="true"
                    android:padding="6dp"/>
            </LinearLayout>

            <!-- 预警预览列表 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_alerts_preview"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"/>

            <TextView
                android:id="@+id/tv_empty_alerts"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="center" android:padding="32dp"
                android:text="@string/empty_alerts"
                android:textColor="@color/text_hint" android:textSize="14sp"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
