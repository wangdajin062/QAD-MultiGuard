<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_gray">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:navigationIconTint="@color/white"
        app:title="@string/report_title"
        app:titleTextAppearance="@style/TextToolbar"
        app:navigationIcon="?attr/homeAsUpIndicator"/>

    <ScrollView
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:fillViewport="true">
        <LinearLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="@string/report_target_hint"
                app:boxStrokeColor="@color/primary"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_target"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="phone" android:maxLength="11"
                    android:textSize="16sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="20dp" android:text="风险类型"
                android:textStyle="bold" android:textSize="14sp"
                android:textColor="@color/text_primary"/>

            <RadioGroup
                android:id="@+id/rg_type"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginTop="8dp">
                <RadioButton android:id="@+id/rb_fraud" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="@string/report_type_phone"
                    android:checked="true" android:textColor="@color/text_primary"
                    android:buttonTint="@color/primary"/>
                <RadioButton android:id="@+id/rb_harass" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="@string/report_type_sms"
                    android:layout_marginTop="8dp" android:textColor="@color/text_primary"
                    android:buttonTint="@color/primary"/>
                <RadioButton android:id="@+id/rb_spam" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="@string/report_type_link"
                    android:layout_marginTop="8dp" android:textColor="@color/text_primary"
                    android:buttonTint="@color/primary"/>
            </RadioGroup>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/report_desc_hint"
                app:boxStrokeColor="@color/primary"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_description"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:minHeight="120dp"
                    android:gravity="top|start" android:inputType="textMultiLine"
                    android:maxLength="500"/>
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_submit"
                style="@style/BtnPrimary"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:layout_marginTop="24dp"
                android:text="@string/report_submit"
                android:textSize="16sp"/>

            <ProgressBar android:id="@+id/progress"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                style="?android:attr/progressBarStyleHorizontal"
                android:indeterminate="true" android:visibility="gone"
                android:indeterminateTint="@color/primary"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
